# Copy to .env for local development. Never commit the real .env file.

DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Leave unset locally to fall back to sqlite. On Railway this is provided
# automatically by the attached PostgreSQL plugin.
# DATABASE_URL=postgres://user:password@localhost:5432/minitools_hub
