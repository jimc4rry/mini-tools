# Copy to .env for local development. Never commit the real .env file.

DJANGO_SETTINGS_MODULE=config.settings.dev
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=

# Canonical site URL used for canonical/og:url tags and the sitemap. Set this
# to the real production domain once you have one (e.g. https://minitoolshub.com) —
# left as localhost otherwise.
SITE_URL=http://127.0.0.1:8000

# Leave unset locally to fall back to sqlite. On Railway this is provided
# automatically by the attached PostgreSQL plugin.
# DATABASE_URL=postgres://user:password@localhost:5432/minitools_hub

# --- Expiration Tracker app (apps/tracker) ---
# Email digests use the console backend until these are set.
# EMAIL_HOST=
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=

# Paddle billing webhook signing secret.
# PADDLE_WEBHOOK_SECRET=

# Twilio WhatsApp notifications.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=
